/* Navigation */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(15, 76, 58, 0.95);
  backdrop-filter: blur(10px);
  z-index: 1000;
  padding: 1rem 0;
  border-bottom: 1px solid rgba(78, 205, 196, 0.2);
}

.nav-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-logo h1 {
  color: #4ecdc4;
  font-size: 1.8rem;
  font-weight: 700;
  letter-spacing: 1px;
}

.nav-link {
  background: none;
  border: none;
  color: #ffffff;
  font-size: 1rem;
  font-weight: 500;
  cursor: pointer;
  padding: 0.5rem 1rem;
  border-radius: 8px;
  transition: all 0.3s ease;
}

.nav-link:hover {
  background: rgba(78, 205, 196, 0.1);
  color: #4ecdc4;
  transform: translateY(-2px);
}

/* Hero Section */
.hero {
  padding: 120px 2rem 80px;
  text-align: center;
  position: relative;
}

.hero::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(78, 205, 196, 0.1) 0%, transparent 70%);
  border-radius: 50%;
  z-index: -1;
}

.hero-container {
  max-width: 800px;
  margin: 0 auto;
}

.hero-title {
  font-size: 3.5rem;
  color: #ffffff;
  margin-bottom: 1rem;
  font-weight: 700;
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
  animation: fadeInUp 1s ease-out;
}

.hero-subtitle {
  font-size: 1.5rem;
  color: #4ecdc4;
  margin-bottom: 0.5rem;
  font-weight: 500;
  animation: fadeInUp 1s ease-out 0.2s both;
}

.hero-description {
  font-size: 1.2rem;
  color: #a0c4b8;
  margin-bottom: 2.5rem;
  animation: fadeInUp 1s ease-out 0.4s both;
}

.hero-buttons {
  display: flex;
  gap: 1.5rem;
  justify-content: center;
  flex-wrap: wrap;
  animation: fadeInUp 1s ease-out 0.6s both;
}

/* Buttons */
.btn {
  padding: 1rem 2rem;
  border-radius: 50px;
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  border: none;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  min-width: 160px;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.btn:hover::before {
  left: 100%;
}

.btn-primary {
  background: linear-gradient(45deg, #4ecdc4, #44b3aa);
  color: #ffffff;
  box-shadow: 0 4px 15px rgba(78, 205, 196, 0.3);
}

.btn-primary:hover {
  background: linear-gradient(45deg, #44b3aa, #3a9a94);
  transform: translateY(-3px);
  box-shadow: 0 8px 25px rgba(78, 205, 196, 0.4);
}

.btn-secondary {
  background: transparent;
  color: #4ecdc4;
  border: 2px solid #4ecdc4;
}

.btn-secondary:hover {
  background: #4ecdc4;
  color: #0f4c3a;
  transform: translateY(-3px);
  box-shadow: 0 8px 25px rgba(78, 205, 196, 0.3);
}

/* Features Section */
.features {
  padding: 80px 2rem;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
}

.features-container {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2rem;
}

@media (max-width: 768px) {
  .features-container {
    grid-template-columns: 1fr;
  }
}

.feature-card {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  padding: 2.5rem;
  border-radius: 20px;
  text-align: center;
  transition: all 0.3s ease;
  border: 1px solid rgba(78, 205, 196, 0.2);
  position: relative;
  overflow: hidden;
}

.feature-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(78, 205, 196, 0.1) 0%, transparent 50%);
  transition: opacity 0.3s ease;
  opacity: 0;
}

.feature-card:hover::before {
  opacity: 1;
}

.feature-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 20px 40px rgba(78, 205, 196, 0.2);
  border-color: rgba(78, 205, 196, 0.5);
}

.feature-icon {
  width: 80px;
  height: 80px;
  background: linear-gradient(45deg, #4ecdc4, #44b3aa);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.5rem;
  transition: all 0.3s ease;
}

.feature-card:hover .feature-icon {
  transform: scale(1.1) rotate(360deg);
}

.feature-icon svg {
  width: 40px;
  height: 40px;
  color: #ffffff;
}

.feature-card h3 {
  color: #ffffff;
  font-size: 1.4rem;
  margin-bottom: 1rem;
  font-weight: 600;
}

.feature-card p {
  color: #a0c4b8;
  line-height: 1.6;
  font-size: 0.95rem;
}

/* How It Works Section */
.how-it-works {
  padding: 80px 2rem;
  text-align: center;
}

.works-container {
  max-width: 1200px;
  margin: 0 auto;
}

.works-container h2 {
  font-size: 2.5rem;
  color: #ffffff;
  margin-bottom: 1rem;
  font-weight: 700;
}

.works-subtitle {
  font-size: 1.2rem;
  color: #a0c4b8;
  margin-bottom: 3rem;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.process-steps {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
  margin-top: 3rem;
}

.step {
  position: relative;
  padding: 2rem 1rem;
}

.step-icon {
  width: 100px;
  height: 100px;
  background: linear-gradient(135deg, #4ecdc4, #44b3aa);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.5rem;
  transition: all 0.4s ease;
  position: relative;
  box-shadow: 0 10px 30px rgba(78, 205, 196, 0.3);
}

.step:hover .step-icon {
  transform: scale(1.15);
  box-shadow: 0 15px 40px rgba(78, 205, 196, 0.5);
}

.step-icon svg {
  width: 50px;
  height: 50px;
  color: #ffffff;
}

.step h3 {
  color: #ffffff;
  font-size: 1.3rem;
  margin-bottom: 1rem;
  font-weight: 600;
}

.step p {
  color: #a0c4b8;
  line-height: 1.6;
  font-size: 0.95rem;
}

/* About Us Section */
.about-us {
  padding: 80px 2rem;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);
}

.about-container {
  max-width: 800px;
  margin: 0 auto;
  text-align: center;
}

.about-content h2 {
  font-size: 2.5rem;
  color: #ffffff;
  margin-bottom: 2rem;
  font-weight: 700;
}

.about-content p {
  font-size: 1.1rem;
  color: #a0c4b8;
  line-height: 1.8;
  margin-bottom: 2.5rem;
}

.working-btn {
  margin-top: 1rem;
}

/* Footer */
.footer {
  background: rgba(15, 76, 58, 0.9);
  padding: 3rem 2rem 2rem;
  border-top: 1px solid rgba(78, 205, 196, 0.2);
}

.footer-container {
  max-width: 1200px;
  margin: 0 auto;
  text-align: center;
}

.footer-content h3 {
  color: #4ecdc4;
  font-size: 1.5rem;
  margin-bottom: 0.5rem;
  font-weight: 700;
}

.footer-content p {
  color: #a0c4b8;
  font-size: 1rem;
}

/* Animations */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Responsive Design */
@media (max-width: 768px) {
  .hero-title {
    font-size: 2.5rem;
  }
  
  .hero-subtitle {
    font-size: 1.2rem;
  }
  
  .hero-description {
    font-size: 1rem;
  }
  
  .hero-buttons {
    flex-direction: column;
    align-items: center;
  }
  
  .features-container {
    grid-template-columns: 1fr;
  }
  
  .process-steps {
    grid-template-columns: 1fr;
  }
  
  .nav-container {
    padding: 0 1rem;
  }
  
  .nav-logo h1 {
    font-size: 1.5rem;
  }
}