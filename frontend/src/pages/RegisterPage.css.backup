.register-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* Background Elements */
.register-bg-elements {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.floating-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.1;
  animation: float 6s ease-in-out infinite;
}

.circle-1 {
  width: 200px;
  height: 200px;
  background: linear-gradient(45deg, #4ecdc4, #44b3aa);
  top: 10%;
  left: 10%;
  animation-delay: 0s;
}

.circle-2 {
  width: 150px;
  height: 150px;
  background: linear-gradient(135deg, #44b3aa, #3a9a94);
  top: 60%;
  right: 15%;
  animation-delay: 2s;
}

.circle-3 {
  width: 100px;
  height: 100px;
  background: linear-gradient(225deg, #4ecdc4, #45b7aa);
  bottom: 20%;
  left: 20%;
  animation-delay: 4s;
}

.circle-4 {
  width: 80px;
  height: 80px;
  background: linear-gradient(315deg, #3a9a94, #2d8075);
  top: 30%;
  right: 30%;
  animation-delay: 1s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px) rotate(0deg);
  }
  33% {
    transform: translateY(-20px) rotate(120deg);
  }
  66% {
    transform: translateY(10px) rotate(240deg);
  }
}

/* Navigation */
.register-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(15, 76, 58, 0.95);
  backdrop-filter: blur(10px);
  z-index: 1000;
  padding: 1rem 0;
  border-bottom: 1px solid rgba(78, 205, 196, 0.2);
}

.register-nav-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
}

.register-logo {
  text-decoration: none;
}

.register-logo h1 {
  color: #4ecdc4;
  font-size: 1.8rem;
  font-weight: 700;
  letter-spacing: 1px;
  transition: all 0.3s ease;
}

.register-logo:hover h1 {
  color: #45b7aa;
  transform: scale(1.05);
}

/* Register Container */
.register-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 2rem;
  position: relative;
}

/* Register Card */
.register-card {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20px);
  border-radius: 24px;
  padding: 3rem 2.5rem;
  width: 100%;
  max-width: 500px;
  border: 1px solid rgba(78, 205, 196, 0.2);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  position: relative;
  overflow: hidden;
  z-index: 10;
  margin-top: 80px;
}

.register-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #4ecdc4, #44b3aa, #4ecdc4);
  background-size: 200% 100%;
  animation: shimmer 2s linear infinite;
}

@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

/* Header */
.register-header {
  text-align: center;
  margin-bottom: 2.5rem;
}

.register-brand {
  color: #4ecdc4;
  font-size: 2rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  letter-spacing: 1px;
}

.register-title {
  color: #ffffff;
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.register-subtitle {
  color: #a0c4b8;
  font-size: 1rem;
  margin: 0;
}

/* Form */
.register-form {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.form-label {
  color: #ffffff;
  font-size: 0.95rem;
  font-weight: 500;
  margin-bottom: 0.5rem;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.form-input {
  width: 100%;
  padding: 1rem 1rem 1rem 3rem;
  background: rgba(255, 255, 255, 0.1);
  border: 2px solid rgba(78, 205, 196, 0.3);
  border-radius: 12px;
  color: #ffffff;
  font-size: 1rem;
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
}

.form-input::placeholder {
  color: #a0c4b8;
}

.form-input:focus {
  outline: none;
  border-color: #4ecdc4;
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 0 0 20px rgba(78, 205, 196, 0.2);
  transform: translateY(-2px);
}

.form-input.error {
  border-color: #ff6b6b;
  box-shadow: 0 0 20px rgba(255, 107, 107, 0.2);
}

.input-icon {
  position: absolute;
  left: 1rem;
  width: 20px;
  height: 20px;
  color: #a0c4b8;
  transition: all 0.3s ease;
}

.form-input:focus + .input-icon {
  color: #4ecdc4;
}

.input-icon svg {
  width: 100%;
  height: 100%;
}

.password-toggle {
  position: absolute;
  right: 1rem;
  background: none;
  border: none;
  color: #a0c4b8;
  cursor: pointer;
  width: 20px;
  height: 20px;
  transition: all 0.3s ease;
}

.password-toggle:hover {
  color: #4ecdc4;
  transform: scale(1.1);
}

.password-toggle svg {
  width: 100%;
  height: 100%;
}

.error-message {
  color: #ff6b6b;
  font-size: 0.85rem;
  margin-top: 0.25rem;
  padding: 0.5rem 0.75rem;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 6px;
  border: 1px solid rgba(255, 107, 107, 0.3);
}

/* Register Button */
.register-button {
  background: linear-gradient(45deg, #4ecdc4, #44b3aa);
  border: none;
  border-radius: 12px;
  padding: 1rem 2rem;
  color: #ffffff;
  font-size: 1.1rem;
  font-weight: 600;
  cursor: pointer;
  margin-top: 1rem;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(78, 205, 196, 0.3);
}

.register-button::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: all 0.3s ease;
}

.register-button:hover::before {
  width: 300px;
  height: 300px;
}

.register-button:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 30px rgba(78, 205, 196, 0.4);
}

.register-button:active {
  transform: translateY(-1px);
}

.register-button span {
  position: relative;
  z-index: 1;
}

/* Links */
.register-login {
  text-align: center;
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(78, 205, 196, 0.2);
  color: #a0c4b8;
  font-size: 0.95rem;
}

.login-link {
  color: #4ecdc4;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
}

.login-link:hover {
  color: #45b7aa;
  text-decoration: underline;
}

/* Decorative Elements */
.register-decorations {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
}

.decoration {
  position: absolute;
  opacity: 0.1;
  animation: rotate 20s linear infinite;
}

.decoration-1 {
  top: 15%;
  left: 15%;
  width: 150px;
  height: 150px;
}

.decoration-2 {
  bottom: 20%;
  right: 20%;
  width: 120px;
  height: 120px;
  animation-direction: reverse;
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* Responsive Design */
@media (max-width: 768px) {
  .register-container {
    padding: 1rem;
  }
  
  .register-card {
    padding: 2rem 1.5rem;
    margin-top: 100px;
  }
  
  .register-brand {
    font-size: 1.7rem;
  }
  
  .register-title {
    font-size: 1.3rem;
  }
  
  .form-input {
    padding: 0.9rem 0.9rem 0.9rem 2.5rem;
  }
  
  .input-icon {
    left: 0.75rem;
  }
  
  .password-toggle {
    right: 0.75rem;
  }
}

@media (max-width: 480px) {
  .register-card {
    padding: 1.5rem 1rem;
    margin-top: 120px;
  }
  
  .register-brand {
    font-size: 1.5rem;
  }
  
  .circle-1, .circle-2, .circle-3, .circle-4 {
    display: none;
  }
}