# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# Server
PORT=5000
ENVIRONMENT=development

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=medivision_db
DB_PORT=3306

# MongoDB
MONGODB_URI=mongodb://localhost:27017/medivision

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload
MAX_FILE_SIZE=10485760

# CORS
FRONTEND_URL=http://localhost:3000

# Gmail SMTP (for OTP emails)
# 1. Enable 2-Step Verification on your Gmail account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password and paste it below (no spaces)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_FROM=MEDIVISION <your_gmail@gmail.com>

# Groq AI (for Dr. Avatar chat)
GROQ_API_KEY=your_groq_api_key

# Google OAuth (optional — for Google Sign-In button)
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
